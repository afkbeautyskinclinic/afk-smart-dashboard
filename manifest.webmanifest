<!doctype html>
<html lang="id">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta http-equiv="refresh" content="0; url=dashboard.html?v=1.5.6">
  <title>AFK Beauty Clinic Smart Dashboard</title>
  <style>
    body {
      margin: 0;
      min-height: 100vh;
      display: grid;
      place-items: center;
      font-family: "Segoe UI", Arial, sans-serif;
      color: #241723;
      background: linear-gradient(135deg, #fff, #fff3f8 62%, #fff7df);
    }
    main {
      width: min(420px, calc(100% - 32px));
      padding: 28px;
      border: 1px solid #eadde5;
      border-radius: 8px;
      background: rgba(255,255,255,.94);
      box-shadow: 0 18px 46px rgba(78,31,58,.1);
      text-align: center;
    }
    img {
      width: 76px;
      height: 76px;
      object-fit: contain;
    }
    h1 {
      margin: 14px 0 8px;
      font-size: 22px;
      line-height: 1.2;
    }
    p {
      margin: 0 0 18px;
      color: #756c76;
    }
    a {
      display: inline-flex;
      min-height: 42px;
      align-items: center;
      justify-content: center;
      padding: 0 18px;
      border-radius: 8px;
      background: #d91f82;
      color: #fff;
      text-decoration: none;
      font-weight: 700;
    }
  </style>
</head>
<body>
  <main>
    <img src="assets/logo-afk.png" alt="AFK Beauty Skin Clinic">
    <h1>AFK Beauty Clinic Smart Dashboard</h1>
    <p>Membuka aplikasi dashboard...</p>
    <a href="dashboard.html?v=1.5.6">Buka Dashboard</a>
  </main>
</body>
</html>
